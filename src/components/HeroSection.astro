---
interface Props {
  headline: string;
  subheadline: string;
  primaryCtaText: string;
  primaryCtaLink: string;
  secondaryCtaText: string;
  secondaryCtaLink: string;
}
const { headline, subheadline, primaryCtaText, primaryCtaLink, secondaryCtaText, secondaryCtaLink } = Astro.props;
---
<section class="hero section">
  <div class="container hero-container">
    <h1 class="hero-title">{headline}</h1>
    <p class="hero-desc">{subheadline}</p>
    <div class="hero-ctas">
      <a href={primaryCtaLink} class="btn btn--primary btn-large">{primaryCtaText}</a>
      <a href={secondaryCtaLink} class="btn btn--outline btn-large">{secondaryCtaText}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--surface);
    border-bottom: 4px solid #000;
    padding: 120px 0;
    text-align: center;
  }
  .hero-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: var(--font-headline-xl-size);
    margin-bottom: var(--spacing-lg);
  }
  .hero-desc {
    font-size: var(--font-body-lg-size);
    margin-bottom: var(--spacing-xl);
    color: var(--on-surface-variant);
  }
  .hero-ctas {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
  }
  .btn-large {
    padding: var(--spacing-md) var(--spacing-xl);
    font-size: 16px;
  }
  @media (max-width: 768px) {
    .hero-title {
      font-size: var(--font-headline-lg-size);
    }
    .hero-ctas {
      flex-direction: column;
    }
  }
</style>
